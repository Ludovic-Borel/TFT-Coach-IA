<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TFTCoach.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TFTCoach.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="TFTCoach.App">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panneau gauche -->
        <StackPanel
        Grid.Column="0"
        Margin="20"
        Spacing="10">

            <ComboBox
            x:Name="ZoneTypeComboBox"
            SelectedIndex="0">

                <ComboBoxItem Content="Board"/>
                <ComboBoxItem Content="Banc"/>
                <ComboBoxItem Content="Boutique"/>
                <ComboBoxItem Content="Gold"/>
                <ComboBoxItem Content="Stage"/>
                <ComboBoxItem Content="Traits"/>
                <ComboBoxItem Content="Augmentations"/>
                <ComboBoxItem Content="Carousel"/>

            </ComboBox>

            <Button
            x:Name="BtnDeleteZone"
            Content="Supprimer la zone"
            Click="BtnDeleteZone_Click"/>

            <ListView
            x:Name="ZonesListView"
            Height="220"/>

            <Button
            x:Name="BtnTest"
            Content="Tester TFT"
            Click="BtnTest_Click"/>

            <TextBlock
            x:Name="TxtStatus"/>

            <TextBlock
            x:Name="TxtRect"/>

        </StackPanel>

        <!-- Capture -->
        <Grid
        Grid.Column="2"
        Width="640"
        Height="360"
        HorizontalAlignment="Center"
        VerticalAlignment="Center">

            <Image
            x:Name="ImgCapture"
            Stretch="Fill"/>

            <Canvas
            x:Name="OverlayCanvas"
            Background="Transparent"
            PointerPressed="OverlayCanvas_PointerPressed"
            PointerMoved="OverlayCanvas_PointerMoved"
            PointerReleased="OverlayCanvas_PointerReleased"/>

        </Grid>

    </Grid>
</Window>