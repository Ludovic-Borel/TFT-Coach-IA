<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TFTCoach.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TFTCoach.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="TFTCoach.App">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="12">

            <ComboBox
                x:Name="ZoneTypeComboBox"
                Width="220"
                 SelectedIndex="0">

                <ComboBoxItem Content="Board"/>
                <ComboBoxItem Content="Banc"/>
                <ComboBoxItem Content="Boutique"/>
                <ComboBoxItem Content="Gold"/>
                <ComboBoxItem Content="Stage"/>
                <ComboBoxItem Content="Traits"/>
                <ComboBoxItem Content="Augmentations"/>
                <ComboBoxItem Content="Carousel"/>

            </ComboBox>
            <Button
                x:Name="BtnTest"
                Width="220"
                Content="Tester TFT"
                Click="BtnTest_Click"/>

            <TextBlock
                x:Name="TxtStatus"
                Text="En attente..."
                HorizontalAlignment="Center"/>

            <TextBlock
                x:Name="TxtRect"
                Text=""
                HorizontalAlignment="Center"/>

            <Grid
                 Width="640"
                 Height="360">

                <Image
                   x:Name="ImgCapture"
                   Stretch="Fill"/>

                <Canvas
                      x:Name="OverlayCanvas"
                      Background="Transparent"
                      PointerPressed="OverlayCanvas_PointerPressed"
                     PointerMoved="OverlayCanvas_PointerMoved"
                     PointerReleased="OverlayCanvas_PointerReleased"/>

            </Grid>

        </StackPanel>
    </Grid>
</Window>